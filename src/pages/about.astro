---
import Layout from '../layouts/Layout.astro';
---

<Layout title="morgan evans — about" currentPage="about" description="Morgan Evans — Sr. Experience Designer at Adobe based in Denver, CO.">
  <div class="max-w-5xl mx-auto px-8 md:px-16 py-16 md:py-24">

    <!-- Header -->
    <div class="mb-16">
      <p class="text-sm tracking-[0.25em] uppercase text-[var(--color-text-muted)] mb-4">about</p>
      <h1 class="font-display text-5xl md:text-6xl font-semibold text-[var(--color-accent)] leading-tight">
        Hello, I'm Morgan.
      </h1>
    </div>

    <!-- Two-column layout -->
    <div class="grid md:grid-cols-2 gap-16">

      <!-- Bio -->
      <div class="space-y-5 text-base leading-relaxed text-[var(--color-text)]">
        <p>
          I'm currently a Staff Product Designer at Adobe, where I lead design for high-impact
          engagement initiatives across the imaging ecosystem — desktop, web, and mobile.
          My recent work focuses on first-time user experiences, onboarding, and in-app systems
          that make Photoshop's powerful content and features more accessible for all users.
        </p>
        <p>
          Over the past decade at Adobe, I've worked across every surface of our creative imaging suite,
          drawing from both my design and engineering background. Along the way, I earned a
          <a href="https://executive.berkeley.edu/programs/product-management-studio" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)]">Certificate in Product Management</a>
          from the Haas School of Business, which strengthened my passion for building thoughtful,
          cross-functional product teams. I love bringing ideas to life through prototyping and animation,
          rapidly iterating to test concepts and get meaningful feedback from customers.
        </p>
        <p>
          Outside of the day-to-day, I'm deeply interested in design strategy, mentorship,
          and shaping the next generation of creative tools.
        </p>
        <p>
          I graduated from the University of Washington with a B.S. in
          <a href="https://ischool.uw.edu/programs/informatics" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)]">Informatics</a>
          with a focus in Human Computer Interaction.
        </p>
        <p class="pt-2">
          <a href="/MorganEvans_Resume.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm tracking-widest uppercase text-[var(--color-accent)] border border-[var(--color-accent)] px-5 py-2.5 hover:bg-[var(--color-accent)] hover:text-white transition-all no-underline">
            view resume
          </a>
        </p>
      </div>

      <!-- Skills -->
      <div class="space-y-8">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-px bg-[var(--color-gold)]"></div>
            <h2 class="font-display text-sm tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-semibold">design</h2>
          </div>
          <ul class="space-y-2 text-sm text-[var(--color-text)]">
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Web Design</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Mobile Design</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Interaction Design</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Prototyping</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> User Research</li>
          </ul>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-px bg-[var(--color-gold)]"></div>
            <h2 class="font-display text-sm tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-semibold">programming</h2>
          </div>
          <ul class="space-y-2 text-sm text-[var(--color-text)]">
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> HTML / CSS</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> JavaScript</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> React</li>
          </ul>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-px bg-[var(--color-gold)]"></div>
            <h2 class="font-display text-sm tracking-[0.2em] uppercase text-[var(--color-text-muted)] font-semibold">misc interests</h2>
          </div>
          <ul class="space-y-2 text-sm text-[var(--color-text)]">
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Product Management</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Mentorship</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Photography</li>
            <li class="flex items-center gap-2"><span class="text-[var(--color-gold)]">+</span> Video Editing & Production</li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</Layout>
